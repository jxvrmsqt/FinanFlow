{
  "name": "finanflow",
  "private": true,
  "version": "1.0.0",
  "main": "main.js",
  "description": "FinanFlow - Gerenciamento Financeiro Inteligente",
  "author": "FinanFlow Team",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build:win": "pnpm run build && electron-builder --win",
    "electron:build:linux": "pnpm run build && electron-builder --linux",
    "electron:build:mac": "pnpm run build && electron-builder --mac"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@google/genai": "^1.41.0",
    "lucide-react": "^0.564.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.finanflow.app",
    "productName": "FinanFlow",
    "copyright": "Copyright © 2026 FinanFlow",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/logo.png",
      "category": "Office"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FinanFlow"
    }
  }
}
